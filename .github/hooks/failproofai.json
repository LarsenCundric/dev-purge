{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "bash": "npx -y failproofai --hook SessionStart --cli copilot",
            "powershell": "npx -y failproofai --hook SessionStart --cli copilot",
            "timeoutSec": 60,
            "__failproofai_hook__": true
          }
        ]
      }
    ],
