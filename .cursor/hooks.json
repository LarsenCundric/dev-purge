{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "command": "npx -y failproofai --hook sessionStart --cli cursor",
        "timeout": 60000,
        "__failproofai_hook__": true
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "command": "npx -y failproofai --hook sessionEnd --cli cursor",
        "timeout": 60000,
        "__failproofai_hook__": true
      }
    ],
    "beforeSubmitPrompt": [
      {
        "type": "command",
        "command": "npx -y failproofai --hook beforeSubmitPrompt --cli cursor",
        "timeout": 60000,
        "__failproofai_hook__": true
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "command": "npx -y failproofai --hook preToolUse --cli cursor",
        "timeout": 60000,
        "__failproofai_hook__": true
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "command": "npx -y failproofai --hook postToolUse --cli cursor",
        "timeout": 60000,
        "__failproofai_hook__": true
      }
    ],
    "stop": [
      {
        "type": "command",
        "command": "npx -y failproofai --hook stop --cli cursor",
        "timeout": 60000,
        "__failproofai_hook__": true
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "command": "npx -y failproofai --hook subagentStop --cli cursor",
        "timeout": 60000,
        "__failproofai_hook__": true
      }
    ]
  }
}
